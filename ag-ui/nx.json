{
  "$schema": "https://nx.dev/reference/nx-json#workspace-configuration",
  "useDaemonProcess": true,
  "parallel": 30,
  "defaultBase": "main",
  "plugins": [
    "@nx/js"
  ],
  "release": {
    "projectsRelationship": "independent",
    "projects": [
      "@ag-ui/core",
      "@ag-ui/client",
      "@ag-ui/encoder",
      "@ag-ui/proto",
      "create-ag-ui-app",
      "@ag-ui/a2ui-toolkit",
      "@ag-ui/a2a",
      "@ag-ui/adk",
      "@ag-ui/ag2",
      "@ag-ui/agno",
      "@ag-ui/aws-strands",
      "@ag-ui/claude-agent-sdk",
      "@ag-ui/cloudflare-agents",
      "@ag-ui/crewai",
      "@ag-ui/langchain",
      "@ag-ui/langgraph",
      "@ag-ui/llamaindex",
      "@ag-ui/mastra",
      "@ag-ui/pydantic-ai",
      "@ag-ui/spring-ai",
      "@ag-ui/watsonx",
      "@ag-ui/a2a-middleware",
      "@ag-ui/a2ui-middleware",
      "@ag-ui/mcp-apps-middleware",
      "@ag-ui/mcp-middleware"
    ]
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*"],
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).ts",
      "!{projectRoot}/**/__tests__/**/*",
      "!{projectRoot}/vitest.config.ts",
      "!{projectRoot}/vitest.config.mts"
    ]
  },
  "targetDefaults": {
    "generate": {
      "outputs": [
        "{projectRoot}/src/generated"
      ],
      "cache": true
    },
    "build": {
      "dependsOn": [
        "^build",
        "generate"
      ],
      "inputs": [
        "production",
        "^production"
      ],
      "outputs": [
        "{projectRoot}/dist",
        "{projectRoot}/.next"
      ],
      "cache": true
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ],
      "cache": true
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ],
      "cache": true
    },
    "dev": {
      "dependsOn": [
        "^build",
        "generate"
      ],
      "cache": false
    },
    "test": {
      "dependsOn": [
        "build"
      ],
      "inputs": [
        "default",
        "^production"
      ],
      "cache": true
    },
    "test:coverage": {
      "dependsOn": [
        "build"
      ],
      "inputs": [
        "default",
        "^production"
      ],
      "outputs": [
        "{projectRoot}/coverage"
      ],
      "cache": true
    },
    "test:watch": {
      "dependsOn": [
        "build"
      ],
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "link:global": {
      "cache": false
    },
    "unlink:global": {
      "cache": false
    },
    "start": {
      "dependsOn": [
        "^build"
      ],
      "cache": false
    }
  }
}