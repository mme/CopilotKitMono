{
  "name": "@ag-ui/claude-agent-sdk",
  "version": "0.0.3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ag-ui-protocol/ag-ui.git"
  },
  "description": "AG-UI integration for Anthropic Claude Agent SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "dev:examples": "tsx --env-file=.env --watch examples/server.ts",
    "clean": "rm -rf dist .turbo node_modules",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "link:global": "pnpm link --global",
    "unlink:global": "pnpm unlink --global"
  },
  "dependencies": {
    "rxjs": "7.8.1"
  },
  "peerDependencies": {
    "@ag-ui/client": ">=0.0.42",
    "@ag-ui/core": ">=0.0.42",
    "@anthropic-ai/claude-agent-sdk": "^0.2.58",
    "@anthropic-ai/sdk": ">=0.50.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@ag-ui/client": "workspace:*",
    "@ag-ui/core": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.2.58",
    "@types/node": "^20.11.19",
    "tsup": "^8.0.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
