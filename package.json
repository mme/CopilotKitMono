{
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "devDependencies": {
    "nx": "22.7.5"
  },
  "scripts": {
    "build:packages": "pnpm nx run-many -t build --projects='@copilotkit/*,@copilotkitnext/*,@ag-ui/*'",
    "dev:packages": "pnpm build:packages && pnpm nx watch --projects='@copilotkit/*,@copilotkitnext/*,@ag-ui/*' -- pnpm nx run \\$NX_PROJECT_NAME:build",
    "dev:demo": "rm -rf CopilotKit/examples/v2/react/demo/.next && pnpm --filter demo dev",
    "dev:dojo": "rm -rf ag-ui/apps/dojo/.next && pnpm --filter demo-viewer dev",
    "mono:branch": "node scripts/mono/branch.mjs",
    "mono:push": "node scripts/mono/push.mjs",
    "mono:pull": "node scripts/mono/pull.mjs",
    "mono:pr": "node scripts/mono/pr.mjs",
    "mono:status": "node scripts/mono/status.mjs",
    "mono:finish": "node scripts/mono/finish.mjs",
    "mono:sync": "node scripts/mono/sync.mjs"
  },
  "pnpm": {
    "overrides": {
      "@ag-ui/a2a": "workspace:*",
      "@ag-ui/a2a-middleware": "workspace:*",
      "@ag-ui/a2ui-middleware": "workspace:*",
      "@ag-ui/adk": "workspace:*",
      "@ag-ui/ag2": "workspace:*",
      "@ag-ui/agno": "workspace:*",
      "@ag-ui/aws-strands": "workspace:*",
      "@ag-ui/claude-agent-sdk": "workspace:*",
      "@ag-ui/client": "workspace:*",
      "@ag-ui/core": "workspace:*",
      "@ag-ui/crewai": "workspace:*",
      "@ag-ui/encoder": "workspace:*",
      "@ag-ui/langchain": "workspace:*",
      "@ag-ui/langgraph": "workspace:*",
      "@ag-ui/langroid": "workspace:*",
      "@ag-ui/llamaindex": "workspace:*",
      "@ag-ui/mastra": "workspace:*",
      "@ag-ui/mcp-apps-middleware": "workspace:*",
      "@ag-ui/middleware-starter": "workspace:*",
      "@ag-ui/proto": "workspace:*",
      "@ag-ui/pydantic-ai": "workspace:*",
      "@ag-ui/server-starter": "workspace:*",
      "@ag-ui/server-starter-all-features": "workspace:*",
      "@ag-ui/spring-ai": "workspace:*",
      "@ag-ui/vercel-ai-sdk": "workspace:*",
      "@copilotkit/a2ui-renderer": "workspace:*",
      "@copilotkit/react-core": "workspace:*",
      "@copilotkit/react-textarea": "workspace:*",
      "@copilotkit/react-ui": "workspace:*",
      "@copilotkit/runtime": "workspace:*",
      "@copilotkit/runtime-client-gql": "workspace:*",
      "@copilotkit/sdk-js": "workspace:*",
      "@copilotkit/shared": "workspace:*",
      "@copilotkit/voice": "workspace:*",
      "@copilotkitnext/agent": "workspace:*",
      "@copilotkitnext/angular": "workspace:*",
      "@copilotkitnext/core": "workspace:*",
      "@copilotkitnext/demo-agents": "workspace:*",
      "@copilotkitnext/eslint-config": "workspace:*",
      "@copilotkitnext/react": "workspace:*",
      "@copilotkitnext/runtime": "workspace:*",
      "@copilotkitnext/shared": "workspace:*",
      "@copilotkitnext/sqlite-runner": "workspace:*",
      "@copilotkitnext/typescript-config": "workspace:*",
      "@copilotkitnext/web-inspector": "workspace:*"
    }
  }
}
